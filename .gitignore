lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.pyo
.pytest_cache/
pytestdebug.log

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff:
instance/
.webassets-cache

# Scrapy stuff:
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   defined in the pyproject.toml.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, lock files should be committed unless it's a library.
# Pipfile.lock

# poetry
#   Similar to Pipenv, see https://python-poetry.org/docs/basic-usage/#commit-your-pyprojecttoml-and-poetrylock-files-to-version-control
# poetry.lock

# pdm
#   Similar to Pipenv, see https://pdm.fming.dev/latest/usage/project/#commit-the-lock-file
# pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
build/
dist/

# Spyder project settings
.spyderproject
.spyproject

# Rope project settings
.ropeproject

# mkdocs documentation
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# pytype static type analyzer
.pytype/

# Cython debug symbols
cython_debug/

# Aegis State (Keep baseline/rules, ignore evolution/logs if personal)
# Actually, for Aegis, we usually WANT to commit rules.yaml and baseline.json.
# We ignore the state files that might contain local session data.
.aegis/discovery_state.json

# Environment
.env
.venv
.vscode/
.idea/
*.swp
*.bak
